// prisma/schema.prisma

// 1. Prismaの基本設定（どの冷蔵庫を使うか）
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Auth.js (NextAuth) が必要とする「顧客名簿」の設計図
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // 会員ステータスと権限
  role          String    @default("user") // "user" or "admin"
  plan          String    @default("free") // "free" or "pro"

  // 経営分析のための時間軸スタンプ
  createdAt      DateTime  @default(now())      
  lastLoginAt    DateTime  @default(now())      
  
  proSubscribedAt DateTime?                      
  proCancelledAt  DateTime?                      

  // プッシュ通知の「宛先情報（郵便受け）」
  pushSubscription String? @db.Text              

  // ★ 追加1：VIP（PRO）昇格のための「パントリー補充回数（熟練度）」
  restockCount  Int       @default(0)

  // 生体認証の際に発行する「一時的な合言葉（チャレンジ）」を記憶する枠
  currentChallenge String? @db.Text

  // ★ 追加2：Stripeカスタマーポータルへ案内するための「顧客ID」の控え
  stripeCustomerId String? @unique

  accounts      Account[]
  sessions      Session[]
  items         Item[]    

  // お客様が残した「声（Voix）」との繋がり
  feedbacks     Feedback[]

  // お客様が登録した「顔や指紋（Authenticator）」の鍵束
  authenticators Authenticator[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// HabiTap 専用の「消耗品（食材）」の設計図
// ==========================================

model Item {
  id          String   @id @default(cuid())
  userId      String
  name        String
  stock       Int      // 現在の在庫数
  maxStock    Int      // 満タン時の数
  daysLeft    Int      // 残り何日分か（UI表示用）
  imageUrl    String?
  amazonUrl   String?
  
  // 自動消費のための新しい「熟成のルール」
  consumeDays   Int      @default(1) 
  consumeAmount Int      @default(1) 
  lastAutoConsumedAt DateTime @default(now()) 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// Voix（お客様の声）を保存する専用の器
// ==========================================
model Feedback {
  id          String   @id @default(cuid())
  userId      String
  message     String   @db.Text
  createdAt   DateTime @default(now())
  
  isResolved  Boolean  @default(false)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 生体認証（パスキー）の公開鍵を保存する金庫
// ==========================================
model Authenticator {
  id                   String  @id @default(cuid())
  credentialID         String  @unique      // デバイス固有のID
  userId               String
  credentialPublicKey  String  @db.Text     // 指紋や顔の暗号データ（Base64形式）
  counter              Int                  // 偽造防止のための使用回数カウンター
  transports           String?              // 認証経路（NFC, 内部センサーなど）

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}